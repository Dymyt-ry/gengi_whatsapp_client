<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_backend_url"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/edit_backend_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_backend_url"
        android:inputType="textUri"
        android:textColor="#ffffff"
        android:textColorHint="#888888"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_api_token"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/edit_api_token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_api_token"
        android:inputType="textPassword"
        android:textColor="#ffffff"
        android:textColorHint="#888888"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save" />

</LinearLayout>
